# brew
if [[ $(uname -m) == arm64 ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# editor
export EDITOR=vim

# direnv
eval "$(direnv hook zsh)"

# mise
eval "$(mise activate zsh)"

# golang
export GOPATH=$HOME/go
export PATH=${GOPATH}/bin:${PATH}

# npm global bin path
export PATH="$PATH:$(npm prefix -g)/bin"


# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PATH:$PNPM_HOME/bin" ;;
esac

# bun global bin path
export PATH="$PATH:$HOME/.bun/bin"

# diff-highlight (brew の git 同梱 Perl スクリプトを直接 PATH へ。symlink 管理不要)
path=("${HOMEBREW_PREFIX:-/opt/homebrew}/opt/git/share/git-core/contrib/diff-highlight" $path)

alias gti='git'

# color the diff
if [[ -x `which colordiff` ]]; then
  alias diff='colordiff -u'
else
  alias diff='diff -u'
fi

# less settings
# - color text
# - display line numbers
export LESS='-R'
export LESSOPEN='| /opt/homebrew/bin/src-hilite-lesspipe.sh %s'

# fzf
export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git"'

# jumo
eval "$(jump shell --bind=z)"

# kubectl
alias k='kubectl'
alias kg='kubectl get'
alias kd='kubectl describe'
alias ka='kubectl apply'
alias kl='kubectl logs -f'
alias ke='kubectl exec -it'
alias krm='kubectl delete'
alias wk='watch kubectl'
alias wkg='watch kubectl get'
alias wkd='watch kubectl describe'
source <(kubectl completion zsh)
compdef __start_kubectl k
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

# terraform
alias tf='op run --env-file=$HOME/dotfiles/op/aws_env -- terraform'
alias tfp='op run --env-file=$HOME/dotfiles/op/aws_env -- terraform plan --parallelism=30'
alias tfa='op run --env-file=$HOME/dotfiles/op/aws_env -- terraform apply'
alias terraform='op run --env-file=$HOME/dotfiles/op/aws_env -- terraform'

export GPG_TTY=$(tty)

# gcloud
export PATH=/opt/homebrew/share/google-cloud-sdk/bin:"$PATH"

# claude code
export PATH="$HOME/.local/bin:$PATH"

# 1password
if [[ -f ~/.config/op/plugins.sh ]]; then
  source ~/.config/op/plugins.sh
fi

# my command
fif() {
  if [ ! "$#" -gt 0 ]; then echo "Need a string to search for!"; return 1; fi
  file=$(rg --hidden --files-with-matches --no-messages -g '!.git' "$1" | fzf --preview "highlight -O ansi -l {} 2> /dev/null | rg --colors 'match:bg:yellow' --ignore-case --pretty --context 10 '$1' || rg --ignore-case --pretty --context 10 '$1' {}")
  if [ -n "$file" ]; then
    less ${file}
    echo ${file}
  fi
}

git_history() {
  file=$(rg --files --hidden . | fzf --preview 'cat {}')
  if [ -n "$file" ]; then
    git log -p ${file}
  fi
}

ghro() {
  # gh の読み取り専用ラッパー。読み取り専用の Fine-grained PAT でログイン済みの
  # 専用プロファイル(~/.config/ghro)を使う。
  # 親環境の GH_TOKEN 等は保存済み認証より優先され readonly 境界を破りうるため、
  # unset してから実行する(gcloudro が CLOUDSDK_* を除去するのと同じ防御)。
  command env -u GH_TOKEN -u GITHUB_TOKEN -u GH_ENTERPRISE_TOKEN -u GITHUB_ENTERPRISE_TOKEN \
    GH_CONFIG_DIR="$HOME/.config/ghro" gh "$@"
}

gcloudro() {
  # gcloud の読み取り専用ラッパー。書き込み不可は GCP 側 IAM(読み取り専用SAへのなりすまし)が担保する。
  # ここではなりすまし設定の上書き・無効化と、認証/設定系グループを塞ぐ。
  local a

  for a in "$@"; do
    # 認証/クレデンシャル/設定を上書き・情報漏洩しうるフラグを拒否
    case "${a%%=*}" in
      --impersonate-service-account|--access-token-file|--flags-file|--configuration|--account|--log-http)
        print -u2 "gcloudro: このフラグは使用できません: $a"
        return 1
        ;;
    esac
    # 認証/設定系グループを拒否(値スキップ不要の堅牢な判定: 該当語がトークンとして現れたら拒否)
    case "$a" in
      auth|config|init|components)
        print -u2 "gcloudro: '$a' グループは使用できません"
        return 1
        ;;
    esac
  done

  # 親環境からの CLOUDSDK_* 注入(API エンドポイント上書き・トークンホスト変更・python 差し替え等)を
  # 一掃してから、1Password 経由で必要な設定(なりすまし先)だけを再注入して実行する
  local -a scrub=()
  for a in ${(k)parameters}; do
    [[ $a == CLOUDSDK_* ]] && scrub+=(-u $a)
  done
  env $scrub op run --env-file "$HOME/dotfiles/op/gcloudro" -- gcloud "$@"
}

alias x86='arch -x86_64 zsh'

# Disable Prezto make wrapper
unfunction make 2>/dev/null
