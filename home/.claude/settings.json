{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(tail:*)",
      "Bash(date:*)",
      "Bash(head:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go mod:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(go fix:*)",
      "Bash(go tool cover:*)",
      "Bash(go list:*)",
      "Bash(go generate:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(goimports:*)",
      "Bash(staticcheck:*)",
      "Bash(golangci-lint:*)",
      "Bash(govulncheck:*)",
      "Bash(gosec:*)",
      "Bash(mockgen:*)",
      "Bash(codex -a never -s read-only:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(gh auth token:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(open:*)",
      "Bash(osascript:*)",
      "Bash(defaults write:*)",
      "Read(**/.env*)",
      "Read(**/credentials*)",
      "Read(**/secret*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Read(**/id_rsa)",
      "Read(**/id_dsa)",
      "Read(**/.ssh/**)",
      "Write(/etc/**)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(kill:*)",
      "Bash(git checkout .)",
      "Bash(git clean -f:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(docker push:*)",
      "Bash(brew install:*)",
      "Bash(mysql:*)",
      "Bash(psql:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block-push-to-main.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock",
        "~/.colima/default/docker.sock",
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.SystemConfiguration.configd",
        "com.apple.secd",
        "com.apple.trustd.agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "/private/tmp",
        "~/Library/Caches",
        "~/**/.git/**",
        "~/.codex",
        "~/go/pkg/mod"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.config/gcloud",
        "~/.bash_history",
        "~/.zsh_history"
      ]
    },
    "excludedCommands": [
      "gh",
      "codex",
      "docker",
      "git"
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh"
}
